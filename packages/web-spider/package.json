    "jsdom": "^29.1.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.19.19",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
